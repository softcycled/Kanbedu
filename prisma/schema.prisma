generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String                   @id @default(cuid())
  email               String                   @unique
  password            String?
  githubId            String?                  @unique
  githubAccessToken   String?
  name                String                   @default("")
  color               String                   @default("#4A90A4")
  createdAt           DateTime                 @default(now())
  boards              BoardMember[]
  invites             BoardInvite[]
  assignedTasks       Task[]                   @relation("TaskAssignees")
  activities          TaskActivity[]
  descriptionVersions TaskDescriptionVersion[]
  bugReports          BugReport[]
}

model Board {
  id          String        @id @default(cuid())
  name        String
  githubRepo  String?
  order       Int           @default(0)
  createdAt   DateTime      @default(now())
  columns   Column[]
  members   BoardMember[]
  invites   BoardInvite[]
  tags      Tag[]
}

model BoardMember {
  id      String @id @default(cuid())
  userId  String
  boardId String
  role    String @default("member")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([userId, boardId])
}

model BoardInvite {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  boardId   String
  createdBy String
  expiresAt DateTime
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  creator   User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([boardId])
}

model Column {
  id      String  @id @default(cuid())
  label   String
  order   Int     @default(0)
  isDone  Boolean @default(false)
  boardId String  @default("cldefaultboard0000")
  board   Board   @relation(fields: [boardId], references: [id])
  tasks   Task[]  @relation("ColumnTasks")

  @@index([boardId])
}

model Task {
  id                  String                   @id @default(cuid())
  title               String
  description         String                   @default("")
  deadline            DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @default(now())
  completedAt         DateTime?
  column              String                   @default("todo")
  columnRel           Column                   @relation("ColumnTasks", fields: [column], references: [id])
  columnUpdatedAt     DateTime                 @default(now())
  assigneeId          String?
  assigneeUser        User?                    @relation("TaskAssignees", fields: [assigneeId], references: [id], onDelete: SetNull)
  order               Float                    @default(0)
  priority            String                   @default("medium")
  movedByNonAssignee  Boolean                  @default(false)
  comments            Comment[]
  columnHistory       TaskColumnHistory[]
  tags                Tag[]
  activities          TaskActivity[]
  descriptionVersions TaskDescriptionVersion[]

  @@index([column])
  @@index([assigneeId])
  @@index([completedAt])
}

model Tag {
  id      String @id @default(cuid())
  name    String
  color   String
  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks   Task[]

  @@unique([boardId, name])
}

model TaskColumnHistory {
  id        String    @id @default(cuid())
  taskId    String
  columnId  String
  enteredAt DateTime  @default(now())
  exitedAt  DateTime?
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([columnId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  author    String   @default("")
  createdAt DateTime @default(now())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskActivity {
  id        String   @id @default(cuid())
  type      String // e.g. "MOVE", "UPDATE", "COMMENT", "TAG", "ASSIGNEE"
  content   String // Human readable or detailed info
  userId    String
  taskId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([type])
}

model TaskDescriptionVersion {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  content   String // The full markdown content at this point in time
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([taskId])
}


model BugReport {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  description String
  browserInfo String?
  status      String   @default("open") // open, in-progress, resolved
  createdAt   DateTime @default(now())

  @@index([userId])
}
