generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String                   @id @default(cuid())
  email               String                   @unique
  handle              String?                  @unique
  password            String?
  name                String                   @default("")
  color               String                   @default("#4A90A4")
  createdAt           DateTime                 @default(now())
  passwordChangedAt   DateTime?
  isAdmin             Boolean                  @default(false)
  emailVerified       Boolean                  @default(false)
  invites             BoardInvite[]
  boards              BoardMember[]
  bugReports          BugReport[]
  comments            Comment[]
  assignedTasks       Task[]                   @relation("TaskAssignees")
  taskAssignments     TaskAssignee[]
  activities          TaskActivity[]
  descriptionVersions TaskDescriptionVersion[]
  emailVerifications  EmailVerification[]
  passwordResetTokens PasswordResetToken[]
  ownedClasses        Class[]                  @relation("ClassOwner")
  classMemberships    ClassMember[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  attachments         Attachment[]
}

// In-app notification feed. Push delivery is best-effort on top of this.
model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String // "ASSIGNED" | "COMMENT" | "MOVED" | "COMPLETED" | "REOPENED"
  title     String
  body      String   @default("")
  read      Boolean  @default(false)
  taskId    String?
  boardId   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@index([taskId])
}

// Browser push endpoint per user/device (Web Push / VAPID).
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Board {
  id             String        @id @default(cuid())
  name           String
  order          Int           @default(0)
  createdAt      DateTime      @default(now())
  realtimeSecret String        @unique @default(cuid())
  invites        BoardInvite[]
  members        BoardMember[]
  columns        Column[]
  tags           Tag[]
  group          Group?
}

model BoardMember {
  id      String @id @default(cuid())
  userId  String
  boardId String
  role    String @default("member")
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, boardId])
  @@index([boardId])
}

model BoardInvite {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  boardId   String
  createdBy String
  expiresAt DateTime
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  creator   User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)

  @@index([boardId])
}

model Column {
  id      String  @id @default(cuid())
  label   String
  order   Int     @default(0)
  isDone  Boolean @default(false)
  color   String? // optional palette name (blue/amber/…); null = color by position
  boardId String  @default("cldefaultboard0000")
  board   Board   @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks   Task[]  @relation("ColumnTasks")

  @@index([boardId])
}

model Task {
  id                  String                   @id @default(cuid())
  title               String
  description         String                   @default("")
  deadline            DateTime?
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @default(now())
  completedAt         DateTime?
  column              String                   @default("todo")
  columnUpdatedAt     DateTime                 @default(now())
  assigneeId          String?
  order               Float                    @default(0)
  priority            String                   @default("medium")
  movedByNonAssignee  Boolean                  @default(false)
  deletedAt           DateTime?                // soft delete: null = live, set = in trash
  deletedBy           String?                  // userId who deleted, for self-restore auth and trash display
  comments            Comment[]
  assigneeUser        User?                    @relation("TaskAssignees", fields: [assigneeId], references: [id])
  assignees           TaskAssignee[]
  columnRel           Column                   @relation("ColumnTasks", fields: [column], references: [id])
  activities          TaskActivity[]
  columnHistory       TaskColumnHistory[]
  descriptionVersions TaskDescriptionVersion[]
  tags                Tag[]                    @relation("TagToTask")
  attachments         Attachment[]

  // Compound (column, order): serves the board load (orderBy column, order),
  // the "last order in column" lookup on task create, and any column-only/FK
  // filter via the column prefix — so it replaces the standalone column index.
  @@index([column, order])
  @@index([assigneeId])
  @@index([completedAt])
  @@index([createdAt])
  @@index([deletedAt])
}

// Full assignee set for a task (multi-assignee). Task.assigneeId is kept in
// sync as the first assignee so legacy single-assignee paths keep working.
model TaskAssignee {
  taskId     String
  userId     String
  assignedAt DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([taskId, userId])
  @@index([userId])
}

model Tag {
  id      String @id @default(cuid())
  name    String
  color   String
  boardId String
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks   Task[] @relation("TagToTask")

  @@unique([boardId, name])
}

model TaskColumnHistory {
  id        String    @id @default(cuid())
  taskId    String
  columnId  String
  enteredAt DateTime  @default(now())
  exitedAt  DateTime?
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([columnId])
  @@index([taskId, enteredAt])
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  author    String   @default("")
  userId    String?  // null for comments posted before this migration
  createdAt DateTime @default(now())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([userId])
}

model TaskActivity {
  id        String   @id @default(cuid())
  type      String
  content   String
  userId    String
  taskId    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([type])
  @@index([taskId, createdAt])
  @@index([userId])
}

model TaskDescriptionVersion {
  id        String   @id @default(cuid())
  taskId    String
  content   String
  userId    String
  createdAt DateTime @default(now())
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model BugReport {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String
  browserInfo String?
  status      String   @default("open")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique @default(cuid())
  expiresAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RateLimit {
  id         String   @id @default(cuid())
  identifier String
  route      String
  hits       Int      @default(1)
  expiresAt  DateTime

  @@unique([identifier, route])
  @@index([expiresAt])
}

// ---- Educator features: Classes, Groups, Presets ----

model Class {
  id        String        @id @default(cuid())
  name      String
  term      String? // e.g. "Fall 2026" — used by reuse-next-semester
  ownerId   String // educator who created it
  joinCode  String        @unique @default(cuid()) // persistent class code (reused all term)
  archived  Boolean       @default(false)
  createdAt DateTime      @default(now())
  owner     User          @relation("ClassOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members       ClassMember[]
  groups        Group[]
  preset        ClassPreset?
  rosterEntries ClassRosterEntry[]

  @@index([ownerId])
}

model ClassMember {
  id          String  @id @default(cuid())
  userId      String
  classId     String
  role        String  @default("student") // "educator" | "ta" | "student"
  groupId     String? // null = lobby (not yet sorted)
  displayName String? // educator-set override from CSV import; shown instead of user.name in class contexts
  order       Int     @default(0)
  class       Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  user        User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  group       Group?  @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@unique([userId, classId])
  @@index([classId])
  @@index([groupId])
}

model ClassRosterEntry {
  id        String  @id @default(cuid())
  classId   String
  email     String  // normalized: lowercase + trim
  name      String  // display name from CSV
  groupName String? // pre-assigned group name from CSV column
  claimedBy String? // userId of the matched account; null = hasn't joined yet
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@unique([classId, email])
  @@index([classId])
}

model Group {
  id      String        @id @default(cuid())
  classId String
  name    String
  order   Int           @default(0)
  boardId String        @unique // each group → exactly one Board (reuses all board infra)
  class   Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  board   Board         @relation(fields: [boardId], references: [id], onDelete: Cascade)
  members ClassMember[]

  @@index([classId])
}

model Attachment {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  url         String
  filename    String
  size        Int
  contentType String
  uploadedBy  String
  uploader    User     @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([taskId])
}

// Snapshot of column layout + seed tasks; materialized into each group board, and cloned on reuse
model ClassPreset {
  id      String @id @default(cuid())
  classId String @unique
  columns Json // [{ label, order, isDone }]
  tasks   Json // [{ title, description, columnIndex, priority }]
  class   Class  @relation(fields: [classId], references: [id], onDelete: Cascade)
}

// Early-access signups for the (unlaunched) Lecturer Pro plan, collected from
// the pricing page. Public, unauthenticated capture; email is unique.
model ProWaitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("pricing") // entry point, in case of future capture surfaces
  createdAt DateTime @default(now())

  @@index([createdAt])
}
