generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String        @id @default(cuid())
  email     String        @unique
  password  String
  name      String        @default("")
  color     String        @default("#4A90A4")
  createdAt DateTime      @default(now())
  boards        BoardMember[]
  invites       BoardInvite[]
  assignedTasks Task[]        @relation("TaskAssignees")
}

model Board {
  id        String        @id @default(cuid())
  name      String
  order     Int           @default(0)
  createdAt DateTime      @default(now())
  columns   Column[]
  members   BoardMember[]
  invites   BoardInvite[]
}

model BoardMember {
  id      String @id @default(cuid())
  userId  String
  boardId String
  role    String @default("member")
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@unique([userId, boardId])
}

model BoardInvite {
  id        String   @id @default(cuid())
  token     String   @unique @default(cuid())
  boardId   String
  createdBy String
  expiresAt DateTime
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  creator   User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
}

model Column {
  id      String  @id @default(cuid())
  label   String
  order   Int     @default(0)
  isDone  Boolean @default(false)
  boardId String  @default("cldefaultboard0000")
  board   Board   @relation(fields: [boardId], references: [id])
}

model Task {
  id               String               @id @default(cuid())
  title            String
  description      String               @default("")
  deadline         DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @default(now())
  completedAt      DateTime?
  column           String               @default("todo")
  columnUpdatedAt  DateTime             @default(now())
  assigneeId       String?
  assigneeUser     User?                @relation("TaskAssignees", fields: [assigneeId], references: [id], onDelete: SetNull)
  order            Float                @default(0)
  priority         String               @default("medium")
  comments         Comment[]
  columnHistory    TaskColumnHistory[]
}

model TaskColumnHistory {
  id        String    @id @default(cuid())
  taskId    String
  columnId  String
  enteredAt DateTime  @default(now())
  exitedAt  DateTime?
  task      Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  author    String   @default("")
  createdAt DateTime @default(now())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
}
